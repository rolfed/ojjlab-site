# Copy this file to .env.local and fill in values.
# .env.local is gitignored and must never be committed.

# ── GymDesk ───────────────────────────────────────────────────────────────────
VITE_GYMDESK_SCHEDULE_URL=
VITE_GYMDESK_LOGIN_URL=

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Required for deployment via wrangler CLI and GitHub Actions.
CLOUDFLARE_API_TOKEN=      # API token: Pages:Edit + Workers:Edit + Account:Read
CLOUDFLARE_ACCOUNT_ID=     # Found in CF dashboard → right sidebar

# ── GHL Calendar embeds (build-time, not secrets) ─────────────────────────────
# Public GHL calendar widget URLs. Safe in client code — not credentials.
# Populate after GHL calendars are created in the GHL dashboard.
VITE_GHL_CALENDAR_EMBED_ADULTS=
VITE_GHL_CALENDAR_EMBED_YOUNG_GRAPPLERS=
VITE_GHL_CALENDAR_EMBED_OLDER_KIDS=
